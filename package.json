{
  "name": "adb-wifi-connect",
  "version": "0.2.1",
  "keywords": [
    "adb",
    "android",
    "connect",
    "mdns",
    "wifi"
  ],
  "author": "Ruben Gees <rubengees7@gmail.com>",
  "repository": "https://github.com/rubengees/adb-wifi-connect",
  "bin": {
    "adb-wifi-connect": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch index.ts",
    "build": "tsgo",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsgo --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm check"
  },
  "dependencies": {
    "@astronautlabs/mdns": "^1.0.10",
    "execa": "^9.6.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@tsconfig/node20": "20.1.9",
    "@types/node": "20.19.39",
    "@types/qrcode": "1.5.6",
    "@typescript/native-preview": "7.0.0-dev.20260501.1",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "prettier": "3.8.3",
    "tsx": "4.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
