{
  "name": "adb-wifi-connect",
  "version": "0.3.0",
  "keywords": [
    "adb",
    "android",
    "connect",
    "mdns",
    "wifi"
  ],
  "author": "Ruben Gees <rubengees7@gmail.com>",
  "repository": "https://github.com/rubengees/adb-wifi-connect",
  "bin": {
    "adb-wifi-connect": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "oxnode --watch index.ts",
    "build": "tsgo",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsgo --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm check"
  },
  "dependencies": {
    "dns-sd-browser": "^1.1.0",
    "execa": "^9.6.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@oxc-node/cli": "0.1.0",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.19.21",
    "@typescript/native-preview": "7.0.0-dev.20260619.1",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
