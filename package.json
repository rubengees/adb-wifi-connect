{
  "name": "adb-wifi-connect",
  "version": "0.3.0",
  "keywords": [
    "adb",
    "android",
    "connect",
    "mdns",
    "wifi"
  ],
  "author": "Ruben Gees <rubengees7@gmail.com>",
  "repository": "https://github.com/rubengees/adb-wifi-connect",
  "bin": {
    "adb-wifi-connect": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "oxnode --watch index.ts",
    "build": "tsgo",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsgo --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm check"
  },
  "dependencies": {
    "dns-sd-browser": "^1.1.0",
    "execa": "^9.6.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@oxc-node/cli": "0.1.0",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.19.19",
    "@typescript/native-preview": "7.0.0-dev.20260605.1",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
