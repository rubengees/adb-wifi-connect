{
  "name": "adb-wifi-connect",
  "version": "0.3.0",
  "keywords": [
    "adb",
    "android",
    "connect",
    "mdns",
    "wifi"
  ],
  "author": "Ruben Gees <rubengees7@gmail.com>",
  "repository": "https://github.com/rubengees/adb-wifi-connect",
  "bin": {
    "adb-wifi-connect": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "oxnode --watch index.ts",
    "build": "tsgo",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsgo --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm check"
  },
  "dependencies": {
    "dns-sd-browser": "^1.1.0",
    "execa": "^9.6.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@oxc-node/cli": "0.1.0",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.19.21",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
