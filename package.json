{
  "name": "adb-wifi-connect",
  "version": "0.3.0",
  "keywords": [
    "adb",
    "android",
    "connect",
    "mdns",
    "wifi"
  ],
  "author": "Ruben Gees <rubengees7@gmail.com>",
  "repository": "https://github.com/rubengees/adb-wifi-connect",
  "bin": {
    "adb-wifi-connect": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "oxnode --watch index.ts",
    "build": "tsgo",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "tsgo --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm check"
  },
  "dependencies": {
    "dns-sd-browser": "^1.1.0",
    "execa": "^9.6.1",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@oxc-node/cli": "0.1.0",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.19.17",
    "@typescript/native-preview": "7.0.0-dev.20260502.1",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.6+sha512.97f906e1da2bedac3df83cadae04b4753a130092dd49d55cd36825ad3e623e9df3f97754f8f259e699172a360fac569acf2f908e7732bdae3eddb2dcf7e121fd"
}
